{
    "hosting": {
        "public": ".",
        "cleanUrls": true,
        "trailingSlash": false,
        "ignore": [
            "firebase.json",
            "database.rules.json",
            "*.rules.json",
            ".firebaserc",
            "node_modules/**",
            ".git/**",
            ".agent/**"
        ],
        "rewrites": [
            {
                "source": "/shop",
                "destination": "/shop/index.html"
            },
            {
                "source": "/shop/**",
                "destination": "/shop/index.html"
            },
            {
                "source": "/product",
                "destination": "/product/index.html"
            },
            {
                "source": "/product/**",
                "destination": "/product/index.html"
            },
            {
                "source": "/cart",
                "destination": "/cart/index.html"
            },
            {
                "source": "/cart/**",
                "destination": "/cart/index.html"
            },
            {
                "source": "/checkout",
                "destination": "/checkout/index.html"
            },
            {
                "source": "/checkout/**",
                "destination": "/checkout/index.html"
            },
            {
                "source": "/dashboard",
                "destination": "/dashboard/index.html"
            },
            {
                "source": "/dashboard/**",
                "destination": "/dashboard/index.html"
            },
            {
                "source": "/login",
                "destination": "/login/index.html"
            },
            {
                "source": "/login/**",
                "destination": "/login/index.html"
            },
            {
                "source": "/admin",
                "destination": "/admin/index.html"
            },
            {
                "source": "/admin/products",
                "destination": "/admin/products/index.html"
            },
            {
                "source": "/admin/orders",
                "destination": "/admin/orders/index.html"
            },
            {
                "source": "/admin/banners",
                "destination": "/admin/banners/index.html"
            },
            {
                "source": "/admin/users",
                "destination": "/admin/users/index.html"
            }
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    {
                        "key": "X-Content-Type-Options",
                        "value": "nosniff"
                    },
                    {
                        "key": "X-Frame-Options",
                        "value": "SAMEORIGIN"
                    },
                    {
                        "key": "X-XSS-Protection",
                        "value": "1; mode=block"
                    },
                    {
                        "key": "Referrer-Policy",
                        "value": "strict-origin-when-cross-origin"
                    }
                ]
            },
            {
                "source": "**/*.@(js|css|png|jpg|webp)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000"
                    }
                ]
            }
        ]
    },
    "database": {
        "rules": "database.rules.json"
    }
}